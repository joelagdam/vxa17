From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
Subject: [PATCH 1/2] power: supply: schgm-flash: add dynamic boost control

Add schgm_flash_set_active() to dynamically control PMI632 flash boost.
When flash is active, force 5V boost + torch priority. When flash turns
off, release both bits so adaptive USB charging resumes.

This fixes the permanent boost issue where FIXED_MODE forced bits at
charger init and never released them, breaking USB charging even after
torch was turned off.

Signed-off-by: Kent <kent@build.local>
---
 drivers/power/supply/qcom/schgm-flash.c | 33 ++++++++++++++++++++++++
 drivers/power/supply/qcom/schgm-flash.h |  1 +
 2 files changed, 34 insertions(+)

diff --git a/drivers/power/supply/qcom/schgm-flash.c b/drivers/power/supply/qcom/schgm-flash.c
index abcdef1..1234567 100644
--- a/drivers/power/supply/qcom/schgm-flash.c
+++ b/drivers/power/supply/qcom/schgm-flash.c
@@ -169,6 +169,39 @@ void schgm_flash_torch_priority(struct smb_charger *chg, enum torch_mode mode)
 	pr_debug("Torch priority changed to: %d\n", mode);
 }
 
+void schgm_flash_set_active(struct smb_charger *chg, bool active)
+{
+	int rc;
+	u8 reg;
+
+	if (chg->headroom_mode == -EINVAL)
+		return;
+
+	/*
+	 * Dynamic boost control: force 5V boost + torch priority ONLY while
+	 * flash is active.  When flash turns off, clear both bits so adaptive
+	 * USB charging can resume.  This replaces the static FIXED_MODE
+	 * behavior that permanently forced these bits at init.
+	 */
+	reg = active ? FORCE_FLASH_BOOST_5V_BIT : 0;
+	rc = smblib_write(chg, SCHGM_FORCE_BOOST_CONTROL, reg);
+	if (rc < 0) {
+		pr_err("Couldn't set force boost control rc=%d\n", rc);
+		return;
+	}
+
+	reg = active ? TORCH_PRIORITY_CONTROL_BIT : 0;
+	rc = smblib_write(chg, SCHGM_TORCH_PRIORITY_CONTROL_REG, reg);
+	if (rc < 0) {
+		pr_err("Couldn't set torch priority control rc=%d\n", rc);
+		return;
+	}
+
+	pr_debug("Flash dynamic boost %s\n", active ? "engaged" : "released");
+}
+
 int schgm_flash_init(struct smb_charger *chg)
 {
 	int rc;
diff --git a/drivers/power/supply/qcom/schgm-flash.h b/drivers/power/supply/qcom/schgm-flash.h
index abcdef1..1234567 100644
--- a/drivers/power/supply/qcom/schgm-flash.h
+++ b/drivers/power/supply/qcom/schgm-flash.h
@@ -49,6 +49,7 @@ int schgm_flash_get_vreg_ok(struct smb_charger *chg, int *val);
 void schgm_flash_torch_priority(struct smb_charger *chg, enum torch_mode mode);
 int schgm_flash_init(struct smb_charger *chg);
 bool is_flash_active(struct smb_charger *chg);
+void schgm_flash_set_active(struct smb_charger *chg, bool active);
 
 irqreturn_t schgm_flash_default_irq_handler(int irq, void *data);
 irqreturn_t schgm_flash_ilim2_irq_handler(int irq, void *data);
